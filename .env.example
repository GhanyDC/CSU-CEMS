# ---------------------------------------------------------------------------
# CEMS – Environment Variables (example / template)
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ---------------------------------------------------------------------------

# Django
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key-at-least-50-characters
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_CSRF_TRUSTED_ORIGINS=
DEBUG=True

# External deployment example:
# DJANGO_ALLOWED_HOSTS=elections.example.edu
# DJANGO_CSRF_TRUSTED_ORIGINS=https://elections.example.edu

# PostgreSQL
POSTGRES_DB=cems
POSTGRES_USER=cems
POSTGRES_PASSWORD=change-me-to-a-secure-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5433

# CEMS application
CEMS_MAX_FAILED_ATTEMPTS=5
CEMS_LOCKOUT_MINUTES=30
CEMS_STUDENT_LOGIN_RATE=300/m
CEMS_ADMIN_LOGIN_RATE=20/m
CEMS_LOGIN_RATE_LIMIT_RETRY_AFTER=60

# Gunicorn (for Docker/production)
GUNICORN_WORKERS=3
DJANGO_RUN_MIGRATIONS=1
DJANGO_COLLECTSTATIC=1

# ---------------------------------------------------------------------------
# Production (Lightsail / Docker Compose)
# ---------------------------------------------------------------------------
# DJANGO_SETTINGS_MODULE=config.settings.production
# DJANGO_ALLOWED_HOSTS=carigcems.com,www.carigcems.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://carigcems.com,https://www.carigcems.com
# DEBUG=False
#
# SSL certs: place fullchain.pem and privkey.pem in /opt/cems/certs/ on host.
# docker-compose.prod.yml mounts /opt/cems/certs:/etc/nginx/certs:ro
